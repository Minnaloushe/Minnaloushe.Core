{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "System.Net": "Debug",
      "System.Net.Http": "Debug",
      "System.Net.Http.SocketsHttpHandler": "Trace",
      "System.Net.Sockets": "Debug",
      "System.Net.NameResolution": "Debug"
    }
  },
  "AllowedHosts": "*",
  "Application": {
    "DataPath": "data"
  },
  "Vault": {
    "ServiceName": "vault",
    "Address": "http://vault:8200",
    "Scheme": "http",
    "Token": "root",
    "MountPoint": "kv"
  },
  "ServiceDiscovery": {
    "ConsulService": "consul",
    "ConsulPort": 8500
  },
  "FolderWatcher": {
    "Path": "/data",
    "Interval": "00:15:00",
    "MaskRegex": ".*\\.(inp|inpx|zip|pdf|fb2|epub|htm|html)$", //Add extensions here if needed
    "EnumerationOptions": {
      "RecurseSubdirectories": true,
      "IncludeFiles": true,
      "IncludeDirectories": false,
      "MatchCasing": "CaseInsensitive",
      "MaxRecursionDepth": 5
    }
  },
  "Telegram": {
    "ReporterBot": {
      "VaultPath": "telegram-reporter-bot",
      "BotToken": "123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11",
      "ChatId": "-1"
    }
  },
  "RepositoryConfiguration": {
    "Connections": [
      {
        "Name": "mongo-default",
        "Type": "mongodb",
        //"ServiceName": "mongo",
        "ConnectionString": "mongodb://root:example@mongodb:27017",
        "Username": "root",
        "Password": "example",
        "DatabaseName": "TestMongoDb",
        "CredentialRenewalInterval": "00:10:00",
        "RetryPolicy": {
          "InitialDelay": "00:00:02",
          "MaxDelay": "00:01:00",
          "MaxRetries": 5,
          "Type": "ExponentialBackoff"
        }
      },
      {
        "Name": "postgres-default",
        //"ServiceName": "postgres",
        "Type": "postgres",
        "ConnectionString": "Host=postgres;Port=5432;Database=app_db;Username=test;Password=password",
        "DatabaseName": "app_db",
        "Username": "test",
        "Password": "password",
        "CredentialRenewalInterval": "00:10:00",
        "RetryPolicy": {
          "InitialDelay": "00:00:02",
          "MaxDelay": "00:01:00",
          "MaxRetries": 5,
          "Type": "ExponentialBackoff"
        }
      }
    ],
    "Repositories": [
      {
        "Name": "TemplateMongoRepository",
        "ConnectionName": "mongo-default",
        "Migrations": {
          "Enabled": false
        }
      },
      {
        "Name": "TemplatePostgresRepository",
        "ConnectionName": "postgres-default",
        "Migrations": {
          "Enabled": false
        }
      }
    ]
  },

  "S3": {
    "vault-s3": {
      "VaultPath": "s3", //No leading slash, effective path is /develop/s3
      "BucketName": "test-bucket-1",
      "SyncRules": true,
      "LifecycleRules": [
        {
          "Prefix": "deleted/",
          "ExpirationInDays": 7
        }
      ]
    },
    "config-s3": {
      "ServiceUrl": "minio:9000",
      "AccessKey": "access_key",
      "SecretKey": "secret_key",
      "BucketName": "test-bucket-2",
      "SyncRules": true,
      "LifecycleRules": [
        {
          "Prefix": "deleted/",
          "ExpirationInDays": 7
        }
      ]
    }
  },
  "Router": {
    "VaultPath": "router-api",
    "Host": "localhost",
    "Port": 123,
    "Username": "user",
    "Password": "pass",
    "ReOpenConnectionAsync": false
  },
  "MessageQueues": {
    "Connections": [
      {
        "Name": "rabbitmq-default",
        "Type": "rabbitmq",
        //"ServiceName": "rabbitmq",
        //"ConnectionString": "amqp://guest:guest@localhost:5672/",
        "CredentialRenewalInterval": "00:10:00",
        "ServiceKey": "TemplateWebApiHost",
        "Username": "user",
        "Password": "password",
        "Host": "rabbitmq",
        "Port": 5672,
        "ConsumerLoopDelay": "00:05:00",
        "ErrorHandling": "DeadLetter",
        "RetryPolicy": {
          "InitialDelay": "00:00:02",
          "MaxDelay": "00:01:00",
          "MaxRetries": 5,
          "Type": "ExponentialBackoff"
        }
      },
      {
        "Name": "rabbitmq-static",
        "Type": "rabbit-static",
        "ServiceName": "rabbitmq",
        "CredentialRenewalInterval": "00:10:00",
        "ServiceKey": "TemplateWebApiHost",
        "Host": "rabbitmq-static",
        "ConsumerLoopDelay": "00:05:00",
        "ErrorHandling": "DeadLetter",
        "RetryPolicy": {
          "InitialDelay": "00:00:02",
          "MaxDelay": "00:01:00",
          "MaxRetries": 5,
          "Type": "ExponentialBackoff"
        }
      },
      {
        "Name": "kafka-default",
        "Type": "kafka",
        //"ServiceName": "kafka",
        "ConnectionString": "kafka:9092",
        "CredentialRenewalInterval": "00:10:00",
        "ServiceKey": "TemplateWebApiHost",
        "Username": "test",
        "Password": "password",
        "Host": "kafka",
        "Port": 9092,
        "ConsumerLoopDelay": "00:05:00",
        "ErrorHandling": "DeadLetter",
        "RetryPolicy": {
          "InitialDelay": "00:00:02",
          "MaxDelay": "00:01:00",
          "MaxRetries": 5,
          "Type": "ExponentialBackoff"
        },
        "Parameters": { //Make sure topic auto creation is disabled in kafka, otherwise behavior 
          // is not defined (topic might be created with kafka default parameters)
          "TopicConfiguration": {
            "NumPartitions": 12,
            "ReplicationFactor": 1,
            "RetentionTime": "7.00:00:00", //7 days
            "RetentionBytes": -1,
            "CleanUpPolicy": "CompactAndDelete",
            "DeleteRetentionTime": "1.00:00:00" //1 day"
          },
          "DltTopicConfiguration": {
            "NumPartitions": 1,
            "ReplicationFactor": 1,
            "RetentionTime": "30.00:00:00", //30 days
            "RetentionBytes": -1,
            "CleanUpPolicy": "Delete",
            "DeleteRetentionTime": "1.00:00:00" //1 day"
          }
        }
      }
    ],
    "Consumers": [
      {
        "Name": "rabbit-consumer", //Queue name or topic name depending on the MQ type
        "ConnectionName": "rabbitmq-default",
        "Parallelism": 1,
        "PrefetchCount": 10,
        "Parameters": { // Topic parameters can be overriden for consumer. Producers will take parameters from connection.
          "TopicConfiguration": {
            "NumPartitions": 12,
            "ReplicationFactor": 1,
            "RetentionTime": "7.00:00:00", //7 days
            "RetentionBytes": -1,
            "CleanUpPolicy": "CompactAndDelete",
            "DeleteRetentionTime": "1.00:00:00" //1 day"
          }
        }
      },
      {
        "Name": "rabbit-consumer-static", //Queue name or topic name depending on the MQ type
        "ConnectionName": "rabbitmq-static",
        "Parallelism": 1,
        "PrefetchCount": 10,
        "Parameters": {
        }
      },
      {
        "Name": "kafka-consumer", //Queue name or topic name depending on the MQ type
        "ConnectionName": "kafka-default",
        "Parallelism": 1,
        "Parameters": {
        }
      },
      {
        "Name": "test-broken-rabbit", //Queue name or topic name depending on the MQ type
        "ConnectionName": "rabbitmq-default",
        //"ServiceKey": "TemplateRabbitMqConsumer",
        "Parallelism": 5,
        "PrefetchCount": 10,
        "Parameters": {
        }
      },
      {
        "Name": "test-broken-kafka", //Queue name or topic name depending on the MQ type
        "ConnectionName": "kafka-default",
        //"ServiceKey": "TemplateRabbitMqConsumer",
        "Parallelism": 1,
        "PrefetchCount": 10,
        "Parameters": {
        }
      }
    ]
  }
}
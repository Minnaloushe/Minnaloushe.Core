DOCKER_REGISTRY=registry.minnaloushe.net

# Vault
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=root

#Consul
CONSUL_ADDR=http://consul:8500

# MongoDB
MONGO_URI="mongodb://mongodb:27017/admin"
MONGO_HOST="mongodb"
MONGO_PORT="27017"
MONGO_USERNAME="root"
MONGO_PASSWORD="example"

# PostgreSQL
POSTGRES_CONN_URL="postgresql://{{username}}:{{password}}@postgres:5432/app_db?sslmode=disable"
POSTGRES_HOST="postgres"
POSTGRES_PORT="5432"
POSTGRES_ADMIN_USER="test"
POSTGRES_ADMIN_PASS="password"

# RabbitMQ
RABBITMQ_HOST="rabbitmq"
RABBITMQ_PORT="5672"
RABBITMQ_USER="user"
RABBITMQ_PASS="password"

# Kafka
KAFKA_USERNAME="test"
KAFKA_PASSWORD="password"

# S3
S3_ACCESS_KEY="access_key"
S3_SECRET_KEY="secret_key"
S3_REGION="us-east-1"
S3_ENDPOINT="minio:9000"
